{
  "name": "news-topic-classifier",
  "version": "1.0.0",
  "description": "Desktop app for News Topic Classification",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "wait-on tcp:5173 && cross-env IS_DEV=true electron .",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "api": "cd .. && python -m uvicorn api.main:app --reload",
    "electron:dev": "concurrently \"npm run api\" \"npm run start\""
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "concurrently": "^8.2.1",
    "cross-env": "^7.0.3",
    "electron": "^26.1.0",
    "electron-is-dev": "^2.0.0",
    "vite": "^4.4.5",
    "wait-on": "^7.0.1"
  }
}
